# OpenClaw Agent Co-ordinator — Environment Variables
# Copy to .env and fill in your values before running setup.sh

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — powers all 4 agents (haiku + sonnet)
ANTHROPIC_API_KEY=

# ── Optional — Fallback model providers ──────────────────────────────────────

# OpenAI — fallback provider
OPENAI_API_KEY=

# Google — Gemini fallback + enables AI summaries in jCodeMunch/jDocMunch
GOOGLE_API_KEY=

# ── Optional — Integrations ───────────────────────────────────────────────────

# GitHub — for agents that push code or open PRs
GITHUB_TOKEN=

# Cognee — long-term memory (default: http://localhost:8200)
# COGNEE_URL=http://localhost:8200
